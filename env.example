# CRM VITAO360 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commitar o .env com valores reais.
#
# Plataforma: Railway
# Configure cada variável no painel do serviço correspondente:
#   Serviço "api"      → variáveis do backend
#   Serviço "web"      → variáveis do frontend
#   Serviço "postgres" → gerenciado automaticamente pelo Railway (DATABASE_URL injetado)

# ============================================================
# Backend — Serviço "api" (Python/FastAPI)
# ============================================================

# Banco de dados PostgreSQL
# Railway injeta automaticamente quando o serviço postgres está linkado ao serviço api.
# Formato Railway: postgresql://user:pass@host:5432/railway
DATABASE_URL=postgresql://user:pass@host:5432/crm_vitao360

# Chave secreta para geração de JWT — gere com: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Origens permitidas pelo CORS (separadas por vírgula)
# Em Railway: usar a URL pública do serviço "web"
# Exemplo: https://web-production-xxxx.up.railway.app
CORS_ORIGINS=http://localhost:3000,https://your-frontend.up.railway.app

# ============================================================
# Integração Deskrio (WhatsApp CRM)
# ============================================================

DESKRIO_API_TOKEN=CHANGE_ME
DESKRIO_API_URL=https://appapi.deskrio.com.br
DESKRIO_COMPANY_ID=38

# ============================================================
# Inteligência Artificial (opcional)
# ============================================================

# Anthropic Claude — usado pelos endpoints /api/ia
ANTHROPIC_API_KEY=CHANGE_ME

# ============================================================
# Frontend — Serviço "web" (Next.js)
# ============================================================

# URL pública do backend FastAPI
# Desenvolvimento local: http://localhost:8000
# Railway (comunicação interna entre serviços): http://api.railway.internal:PORT
# Railway (URL pública, fallback): https://api-production-xxxx.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
