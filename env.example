# ==============================================================================
# CRM VITAO360 — Environment Variables
# ==============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commitar o .env com valores reais no repositorio.
#
# Plataforma: Railway
# Configure cada variavel no painel do servico correspondente:
#   Servico "api"      -> variaveis do backend
#   Servico "web"      -> variaveis do frontend
#   Servico "postgres" -> gerenciado automaticamente pelo Railway (DATABASE_URL injetado)

# ==============================================================================
# Backend — Servico "api" (Python/FastAPI)
# ==============================================================================

# ---------- Banco de dados PostgreSQL ----------
# Railway injeta automaticamente quando o servico postgres esta linkado ao servico api.
# Formato: postgresql://user:pass@host:5432/database
# Desenvolvimento local: pode usar sqlite:///./crm_vitao360.db
DATABASE_URL=postgresql://user:pass@host:5432/crm_vitao360

# Habilita log de todas as queries SQL (apenas desenvolvimento)
# DB_ECHO=1

# ---------- Autenticacao JWT ----------
# IMPORTANTE: Gere uma chave secreta forte e unica para producao.
# Comando para gerar:
#   Linux/Mac: openssl rand -hex 32
#   Python:    python -c "import secrets; print(secrets.token_hex(32))"
#   PowerShell: -join ((1..64) | ForEach {'{0:x}' -f (Get-Random -Max 16)})
#
# NUNCA use o valor padrao "dev-secret-change-in-production" em producao.
# Uma chave fraca permite forjar tokens JWT e acessar qualquer conta.
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# Algoritmo JWT (padrao: HS256 — nao altere sem necessidade)
# JWT_ALGORITHM=HS256

# Duracao do access token em minutos (padrao: 480 = 8 horas, jornada comercial)
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Duracao do refresh token em dias (padrao: 30)
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- CORS — Frontend Next.js ----------
# Origens permitidas (separadas por virgula).
# Em Railway: usar a URL publica do servico "web".
# Exemplo: https://web-production-xxxx.up.railway.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- Integracao Deskrio (WhatsApp CRM) ----------
# Token de acesso a API Deskrio — solicitar ao suporte Deskrio
DESKRIO_API_TOKEN=CHANGE_ME

# URL base da API Deskrio (normalmente nao precisa alterar)
DESKRIO_API_URL=https://appapi.deskrio.com.br

# ID da empresa no Deskrio (verificar no painel administrativo)
DESKRIO_COMPANY_ID=38

# ---------- Inteligencia Artificial (LLM cascata) ----------
# Cascata: DeepInfra -> Groq -> Anthropic -> OpenAI
# Pelo menos UMA key e necessaria. DeepInfra recomendado (35x mais barato).
# Sem nenhuma chave, os endpoints de IA retornam fallback template.
DEEPINFRA_API_KEY=CHANGE_ME           # Primario - $0.13/$0.40 por 1M tokens
# GROQ_API_KEY=CHANGE_ME              # Opcional - latencia <500ms
# ANTHROPIC_API_KEY=CHANGE_ME         # Opcional - premium, mais caro
# OPENAI_API_KEY=CHANGE_ME            # Opcional - fallback universal

# ==============================================================================
# Frontend — Servico "web" (Next.js)
# ==============================================================================

# URL publica do backend FastAPI
# Desenvolvimento local: http://localhost:8000
# Railway (comunicacao interna entre servicos): http://api.railway.internal:PORT
# Railway (URL publica, fallback): https://api-production-xxxx.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
