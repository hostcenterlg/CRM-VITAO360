{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/debug.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/debug",
      "dest": "/api/debug.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/health",
      "dest": "/api/index.py"
    }
  ]
}
