# CRM VITAO360 — Variáveis de Ambiente do Frontend (Next.js)
# Copie este arquivo para .env.local para desenvolvimento local.
# Em Railway: configure via painel do serviço "web" > Variables.

# URL do backend FastAPI
# Desenvolvimento local:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Railway (comunicação interna entre serviços — mais rápido, sem custo de egress):
# NEXT_PUBLIC_API_URL=http://api.railway.internal:PORT
# Railway (URL pública, para testes externos):
# NEXT_PUBLIC_API_URL=https://api-production-xxxx.up.railway.app
